{
    // ── CMake Tools ──────────────────────────────────────────────────────────
    // Build output goes here. CMake Tools reads this automatically.
    "cmake.buildDirectory": "${workspaceFolder}/build",

    // Configure the project automatically when you open the folder
    "cmake.configureOnOpen": true,

    // Always build before launching (so F5 = build + run)
    "cmake.buildBeforeRun": true,

    // Pick the active target via the status bar (bottom of VS Code window)
    "cmake.defaultVariants": {
        "buildType": {
            "default": "debug",
            "choices": {
                "debug": {
                    "short": "Debug",
                    "long": "Disable optimizations, enable validation layers",
                    "buildType": "Debug"
                },
                "release": {
                    "short": "Release",
                    "long": "Enable optimizations, disable validation layers",
                    "buildType": "Release"
                }
            }
        }
    },

    // ── C/C++ IntelliSense ───────────────────────────────────────────────────
    // Tell the C++ extension to use compile_commands.json generated by CMake
    "C_Cpp.default.configurationProvider": "ms-vscode.cmake-tools",

    // ── Editor quality-of-life ───────────────────────────────────────────────
    "editor.formatOnSave": true,
    "files.associations": {
        "*.vert": "glsl",
        "*.frag": "glsl",
        "*.comp": "glsl"
    }
}
