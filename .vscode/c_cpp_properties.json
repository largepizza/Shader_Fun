{
    "configurations": [
        {
            "name": "Win32",
            "includePath": [
                "${workspaceFolder}/src",
                "${workspaceFolder}/build/_deps/glfw-src/include",
                "${workspaceFolder}/build/_deps/glm-src",
                // Vulkan SDK headers — reads your VULKAN_SDK environment variable
                "${env:VULKAN_SDK}/Include"
            ],
            "defines": [
                "_DEBUG",
                "UNICODE",
                "_UNICODE"
            ],
            "cppStandard": "c++20",
            "intelliSenseMode": "windows-msvc-x64",
            // Use compile commands generated by CMake for accurate IntelliSense
            "compileCommands": "${workspaceFolder}/build/compile_commands.json"
        }
    ],
    "version": 4
}
